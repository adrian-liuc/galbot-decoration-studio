            custom double[] inputs:mecanumAngles
            double[] inputs:mecanumAngles.connect = </galbot_one_golf/holonomic_controller/usd_setup_holonomic_robot.outputs:mecanumAngles>
            custom double3 inputs:upAxis
            double3 inputs:upAxis.connect = </galbot_one_golf/holonomic_controller/usd_setup_holonomic_robot.outputs:upAxis>
            custom double3 inputs:wheelAxis
            double3 inputs:wheelAxis.connect = </galbot_one_golf/holonomic_controller/usd_setup_holonomic_robot.outputs:wheelAxis>
